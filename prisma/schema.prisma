generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======================================================
// MÓDULO DE USUARIOS, ROLES, PERMISOS Y ÁREAS
// ======================================================

model usuarios {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @db.VarChar(255)
  apellido   String   @db.VarChar(255)
  email      String   @unique @db.VarChar(255)
  cedula     String   @unique @db.VarChar(20)
  password   String?  @db.VarChar(255)
  es_activo  Boolean? @default(true)
  area_id    String?  @db.Uuid
  rol_id     Int?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  areas_pertenece areas?                @relation("usuarios_area_idToareas", fields: [area_id], references: [id])
  roles           roles?                @relation(fields: [rol_id], references: [id])

  actividades_creadas   actividad[]      @relation("Creador")
  ejecuciones_realizadas ejecucion[]     @relation("Ejecutor")
  logs_actividad        log_actividad[]
}

model roles {
  id             Int              @id @default(autoincrement())
  nombre         String           @unique @db.VarChar(50)
  descripcion    String?
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  roles_permisos roles_permisos[]
  usuarios       usuarios[]
}

model permisos_sistema {
  id             Int              @id @default(autoincrement())
  slug           String           @unique @db.VarChar(100)
  descripcion    String?
  roles_permisos roles_permisos[]
}

model roles_permisos {
  rol_id           Int
  permiso_id       Int
  permisos_sistema permisos_sistema @relation(fields: [permiso_id], references: [id])
  roles            roles            @relation(fields: [rol_id], references: [id])

  @@id([rol_id, permiso_id])
}

model areas {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @db.VarChar(255)
  parent_id  String?  @db.Uuid
  jefe_id    String?  @db.Uuid
  tipo_id    Int?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  areas_parent           areas?                @relation("areas_tree", fields: [parent_id], references: [id])
  areas_children         areas[]               @relation("areas_tree")
  cat_tipos_area         cat_tipos_area?       @relation(fields: [tipo_id], references: [id])
  usuarios_jefe          usuarios?             @relation("usuarios_jefe_area", fields: [jefe_id], references: [id])
  usuarios_miembros      usuarios[]            @relation("usuarios_area_idToareas")
  permiso_supervision    permiso_supervision[]

  planificaciones_oficina_ planificacion[] @relation("OficinaResponsable")
  ejecuciones_oficina_    ejecucion[]     @relation("OficinaEjecutora")
}

model cat_tipos_area {
  id               Int     @id @default(autoincrement())
  nombre           String  @unique @db.VarChar(50)
  nivel_jerarquico Int
  areas            areas[]
}

model permiso_supervision {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_id String    @db.Uuid
  area_id    String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  areas      areas     @relation(fields: [area_id], references: [id])
  usuarios   usuarios  @relation(fields: [usuario_id], references: [id])

  @@unique([usuario_id, area_id])
}

// ======================================================
// MÓDULO DE AGENDA Y EJECUCIÓN DE ACTIVIDADES
// ======================================================

// ------------------------------
// Catálogos básicos
// ------------------------------

model tipo_actividad {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  orden      Int      @default(0)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  planificaciones planificacion[]
}

model prioridad {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(50)
  slug       String   @unique @db.VarChar(50)
  color_hex  String?  @db.VarChar(7)
  orden      Int      @default(0)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  planificaciones planificacion[]
}

model vertice_impacto {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  orden      Int      @default(0)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  planificaciones planificacion[]
}

model linea_estrategica {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(200)
  slug       String   @unique @db.VarChar(200)
  orden      Int      @default(0)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  ejecuciones ejecucion[]
}

model tipo_publico {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  orden      Int      @default(0)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  actividad_publico actividad_publico[]
}

model opcion_participacion_autoridades {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  valor      String   @unique @db.VarChar(50)
  slug       String   @unique @db.VarChar(50)
  orden      Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  planificaciones planificacion[]
}

model espacio_sapi {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(255)
  slug       String   @unique @db.VarChar(255)
  capacidad  Int?
  ubicacion  String?  @db.VarChar(255)
  activo     Boolean  @default(true)
  orden      Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  planificaciones planificacion[]
}

// ------------------------------
// Entidades externas
// ------------------------------

model entidad {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(255)
  sigla      String?  @db.VarChar(50)
  tipo       String?  @db.VarChar(50)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  planificaciones_ente_encargado     planificacion[] @relation("EnteEncargado")
  planificaciones_institucion_convoca planificacion[] @relation("InstitucionConvoca")
}

// ------------------------------
// Contactos
// ------------------------------

model contacto {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @db.VarChar(255)
  telefono   String   @db.VarChar(50)
  email      String?  @db.VarChar(255)
  cargo      String?  @db.VarChar(255)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  planificaciones planificacion[]
}

// ------------------------------
// Comunas
// ------------------------------

model comuna {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @unique @db.VarChar(255)
  slug       String   @unique @db.VarChar(255)
  municipio  String?  @db.VarChar(100)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  ejecuciones ejecucion_comuna[]
}

// ------------------------------
// Ubicación geográfica
// ------------------------------

model ubicacion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estado          String   @db.VarChar(100)
  municipio       String   @db.VarChar(100)
  parroquia       String?  @db.VarChar(100)
  direccion_exacta String? @db.Text
  lugar_nombre    String?  @db.VarChar(255)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  planificaciones planificacion[]
  ejecuciones     ejecucion[]

  @@unique([estado, municipio, parroquia, direccion_exacta])
  @@index([estado, municipio])
}

// ------------------------------
// Actividad (núcleo con flujo de aprobación y ejecución)
// ------------------------------

enum estado_aprobacion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum estado_ejecucion {
  PLANIFICADA
  EJECUTADA
  CANCELADA
  REPROGRAMADA
}

model actividad {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String            @db.VarChar(255)
  descripcion   String?           @db.Text
  estado_aprobacion estado_aprobacion @default(PENDIENTE)
  estado_ejecucion  estado_ejecucion  @default(PLANIFICADA)
  created_at    DateTime          @default(now()) @db.Timestamptz(6)
  updated_at    DateTime          @updatedAt @db.Timestamptz(6)
  deleted_at    DateTime?         @db.Timestamptz(6)

  creado_por_id String           @db.Uuid
  creado_por    usuarios         @relation("Creador", fields: [creado_por_id], references: [id])
  aprobado_por_id String?        @db.Uuid
  aprobado_por  usuarios?        @relation("Aprobador", fields: [aprobado_por_id], references: [id])
  fecha_aprobacion DateTime?     @db.Timestamptz(6)
  motivo_rechazo String?         @db.Text

  planificacion planificacion?
  ejecucion     ejecucion?
  logs          log_actividad[]

  @@index([estado_aprobacion])
  @@index([estado_ejecucion])
  @@index([creado_por_id])
  @@index([aprobado_por_id])
  @@index([created_at])
}

// ------------------------------
// Planificación (incluye duración estimada)
// ------------------------------

model planificacion {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actividad_id               String   @unique @db.Uuid
  fecha_ejecucion_planeada   DateTime @db.Timestamptz(6)
  hora_actividad             String   @db.VarChar(5)   // "09:00"
  duracion_estimada_minutos  Int      //  por ejemplo 120 (2 horas)

  ente_encargado_id          String?  @db.Uuid
  ente_encargado_otro        String?  @db.VarChar(255)

  institucion_convoca_id     String?  @db.Uuid

  oficina_responsable_id     String   @db.Uuid

  trabajador_contacto_id     String?  @db.Uuid

  participacion_autoridades_id String? @db.Uuid

  observaciones              String?  @db.Text
  requerimientos_adicionales String?  @db.Text

  espacio_sapi_id            String?  @db.Uuid

  tipo_actividad_id          String   @db.Uuid
  prioridad_id               String   @db.Uuid
  vertice_impacto_id         String?  @db.Uuid

  ubicacion_id               String   @db.Uuid

  created_at                 DateTime @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime @updatedAt @db.Timestamptz(6)

  actividad                actividad                         @relation(fields: [actividad_id], references: [id])
  ente_encargado           entidad?                          @relation("EnteEncargado", fields: [ente_encargado_id], references: [id])
  institucion_convoca      entidad?                          @relation("InstitucionConvoca", fields: [institucion_convoca_id], references: [id])
  oficina_responsable      areas                             @relation("OficinaResponsable", fields: [oficina_responsable_id], references: [id])
  trabajador_contacto      contacto?                         @relation(fields: [trabajador_contacto_id], references: [id])
  participacion_autoridades opcion_participacion_autoridades? @relation(fields: [participacion_autoridades_id], references: [id])
  espacio_sapi             espacio_sapi?                     @relation(fields: [espacio_sapi_id], references: [id])
  tipo_actividad           tipo_actividad                    @relation(fields: [tipo_actividad_id], references: [id])
  prioridad                prioridad                         @relation(fields: [prioridad_id], references: [id])
  vertice_impacto          vertice_impacto?                  @relation(fields: [vertice_impacto_id], references: [id])
  ubicacion                ubicacion                         @relation(fields: [ubicacion_id], references: [id])

  @@index([fecha_ejecucion_planeada])
  @@index([oficina_responsable_id])
  @@index([tipo_actividad_id])
  @@index([espacio_sapi_id])
}

// ------------------------------
// Ejecución (incluye duración real)
// ------------------------------

model ejecucion {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actividad_id               String   @unique @db.Uuid
  fecha_ejecucion_real       DateTime @db.Timestamptz(6)
  duracion_real_minutos      Int?     // opcional, puede ser diferente a la estimada
  objetivo_actividad         String   @db.Text
  descripcion_ejecucion      String   @db.Text
  cantidad_personas          Int
  total_masculino            Int
  total_femenino             Int

  linea_estrategica_id       String   @db.Uuid
  ubicacion_id               String   @db.Uuid
  oficina_ejecutora_id       String   @db.Uuid
  ejecutado_por_id           String   @db.Uuid

  created_at                 DateTime @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime @updatedAt @db.Timestamptz(6)

  actividad                actividad                @relation(fields: [actividad_id], references: [id])
  linea_estrategica        linea_estrategica        @relation(fields: [linea_estrategica_id], references: [id])
  ubicacion                ubicacion                @relation(fields: [ubicacion_id], references: [id])
  oficina_ejecutora        areas                    @relation("OficinaEjecutora", fields: [oficina_ejecutora_id], references: [id])
  ejecutado_por            usuarios                 @relation("Ejecutor", fields: [ejecutado_por_id], references: [id])

  publicos_atendidos       actividad_publico[]
  comunas_atendidas        ejecucion_comuna[]

  @@index([fecha_ejecucion_real])
  @@index([linea_estrategica_id])
  @@index([oficina_ejecutora_id])
}

// ------------------------------
// Tablas puente
// ------------------------------

model actividad_publico {
  ejecucion_id     String        @db.Uuid
  tipo_publico_id  String        @db.Uuid
  cantidad         Int?
  observacion      String?       @db.Text

  ejecucion        ejecucion     @relation(fields: [ejecucion_id], references: [id])
  tipo_publico     tipo_publico  @relation(fields: [tipo_publico_id], references: [id])

  @@id([ejecucion_id, tipo_publico_id])
  @@index([tipo_publico_id])
}

model ejecucion_comuna {
  ejecucion_id   String   @db.Uuid
  comuna_id      String   @db.Uuid
  observacion    String?  @db.Text

  ejecucion      ejecucion @relation(fields: [ejecucion_id], references: [id])
  comuna         comuna    @relation(fields: [comuna_id], references: [id])

  @@id([ejecucion_id, comuna_id])
  @@index([comuna_id])
}

// ------------------------------
// Auditoría
// ------------------------------

model log_actividad {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actividad_id    String   @db.Uuid
  usuario_id      String   @db.Uuid
  accion          String   @db.VarChar(50)
  estado_anterior_aprobacion String? @db.VarChar(30)
  estado_nuevo_aprobacion   String? @db.VarChar(30)
  estado_anterior_ejecucion String? @db.VarChar(30)
  estado_nuevo_ejecucion   String? @db.VarChar(30)
  detalles        Json?
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  actividad      actividad @relation(fields: [actividad_id], references: [id])
  usuario        usuarios  @relation(fields: [usuario_id], references: [id])

  @@index([actividad_id])
  @@index([usuario_id])
  @@index([created_at])
}