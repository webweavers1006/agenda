generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======================================================
// USERS, ROLES, PERMISSIONS & AREAS MODULE
// ======================================================

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String   @map("nombre") @db.VarChar(255)
  lastName     String   @map("apellido") @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  idNumber     String   @unique @map("cedula") @db.VarChar(20)
  passwordHash String?  @map("password") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("es_activo")
  areaId       String?  @map("area_id") @db.Uuid
  roleId       Int?     @map("rol_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  area                Area?              @relation("UserArea", fields: [areaId], references: [id])
  role                Role?              @relation(fields: [roleId], references: [id])

  createdActivities      Activity[]               @relation("Creator")
  approvedActivities     Activity[]               @relation("Approver")
  executionsPerformed    Execution[]              @relation("Executor")
  activityLogs           ActivityLog[]
  ledAreas               Area[]                   @relation("UserLeaderArea")
  supervisionPermissions SupervisionPermission[]

  @@map("usuarios")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @map("nombre") @db.VarChar(50)
  description String?  @map("descripcion")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model SystemPermission {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(100)
  description String?  @map("descripcion")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permisos_sistema")
}

model RolePermission {
  roleId       Int @map("rol_id")
  permissionId Int @map("permiso_id")

  systemPermission SystemPermission @relation(fields: [permissionId], references: [id])
  role             Role             @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
  @@map("roles_permisos")
}

model Area {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @map("nombre") @db.VarChar(255)
  parentId  String?  @map("parent_id") @db.Uuid
  leaderId  String?  @map("jefe_id") @db.Uuid
  typeId    Int?     @map("tipo_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent                 Area?                     @relation("AreaTree", fields: [parentId], references: [id])
  children               Area[]                    @relation("AreaTree")
  areaType               AreaType?                 @relation(fields: [typeId], references: [id])
  leader                 User?                     @relation("UserLeaderArea", fields: [leaderId], references: [id])
  members                User[]                    @relation("UserArea")
  supervisionPermissions SupervisionPermission[]

  responsiblePlannings Planning[]   @relation("ResponsibleOffice")
  executingExecutions  Execution[]  @relation("ExecutingOffice")

  @@map("areas")
}

model AreaType {
  id             Int      @id @default(autoincrement())
  name           String   @unique @map("nombre") @db.VarChar(50)
  hierarchyLevel Int      @map("nivel_jerarquico")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  areas Area[]

  @@map("cat_tipos_area")
}

model SupervisionPermission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("usuario_id") @db.Uuid
  areaId    String   @map("area_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  area Area @relation(fields: [areaId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([userId, areaId])
  @@map("permiso_supervision")
}

// ======================================================
// ACTIVITY AGENDA & EXECUTION MODULE
// ======================================================

model ActivityType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @map("nombre") @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  sortOrder Int      @default(0) @map("orden")
  isActive  Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannings Planning[]

  @@map("tipo_actividad")
}

model Priority {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @map("nombre") @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  colorHex  String?  @map("color_hex") @db.VarChar(7)
  sortOrder Int      @default(0) @map("orden")
  isActive  Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannings Planning[]

  @@map("prioridad")
}

model ImpactVertex {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @map("nombre") @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  sortOrder Int      @default(0) @map("orden")
  isActive  Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannings Planning[]

  @@map("vertice_impacto")
}

model StrategicLine {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @map("nombre") @db.VarChar(200)
  slug      String   @unique @db.VarChar(200)
  sortOrder Int      @default(0) @map("orden")
  isActive  Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  executions Execution[]

  @@map("linea_estrategica")
}

model AudienceType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @map("nombre") @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  sortOrder Int      @default(0) @map("orden")
  isActive  Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  activityAudiences ActivityAudience[]

  @@map("tipo_publico")
}

model AuthorityParticipationOption {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  value     String   @unique @map("valor") @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  sortOrder Int      @default(0) @map("orden")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannings Planning[]

  @@map("opcion_participacion_autoridades")
}

model SapiSpace {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @map("nombre") @db.VarChar(255)
  slug      String   @unique @db.VarChar(255)
  capacity  Int?     @map("capacidad")
  location  String?  @map("ubicacion") @db.VarChar(255)
  isActive  Boolean  @default(true) @map("activo")
  sortOrder Int      @default(0) @map("orden")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannings Planning[]

  @@map("espacio_sapi")
}

// ------------------------------
// External entities
// ------------------------------

model Entity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @map("nombre") @db.VarChar(255)
  acronym   String?  @map("sigla") @db.VarChar(50)
  type      String?  @map("tipo") @db.VarChar(50)
  isActive  Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  planningsAsResponsible Planning[] @relation("ResponsibleEntity")
  planningsAsConvoker    Planning[] @relation("ConvokingInstitution")

  @@map("entidad")
}

// ------------------------------
// Contacts
// ------------------------------

model Contact {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @map("nombre") @db.VarChar(255)
  phone     String   @map("telefono") @db.VarChar(50)
  email     String?  @db.VarChar(255)
  position  String?  @map("cargo") @db.VarChar(255)
  isActive  Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannings Planning[]

  @@map("contacto")
}

// ------------------------------
// Communes
// ------------------------------

model Commune {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @unique @map("nombre") @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  municipality String?  @map("municipio") @db.VarChar(100)
  isActive     Boolean  @default(true) @map("activo")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  executionCommunes ExecutionCommune[]

  @@map("comuna")
}

// ------------------------------
// Geographic location
// ------------------------------

model Location {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  state        String   @map("estado") @db.VarChar(100)
  municipality String   @map("municipio") @db.VarChar(100)
  parish       String?  @map("parroquia") @db.VarChar(100)
  exactAddress String?  @map("direccion_exacta") @db.Text
  placeName    String?  @map("lugar_nombre") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannings  Planning[]
  executions Execution[]

  @@unique([state, municipality, parish, exactAddress])
  @@index([state, municipality])
  @@map("ubicacion")
}

// ------------------------------
// Activity (core with approval & execution flow)
// ------------------------------

enum ApprovalStatus {
  PENDING   @map("PENDIENTE")
  APPROVED  @map("APROBADA")
  REJECTED  @map("RECHAZADA")

  @@map("estado_aprobacion")
}

enum ExecutionStatus {
  PLANNED     @map("PLANIFICADA")
  EXECUTED    @map("EJECUTADA")
  CANCELLED   @map("CANCELADA")
  RESCHEDULED @map("REPROGRAMADA")

  @@map("estado_ejecucion")
}

model Activity {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @map("nombre") @db.VarChar(255)
  description     String?         @map("descripcion") @db.Text
  approvalStatus  ApprovalStatus  @default(PENDING) @map("estado_aprobacion")
  executionStatus ExecutionStatus @default(PLANNED) @map("estado_ejecucion")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz(6)

  createdById     String  @map("creado_por_id") @db.Uuid
  createdBy       User    @relation("Creator", fields: [createdById], references: [id])
  approvedById    String? @map("aprobado_por_id") @db.Uuid
  approvedBy      User?   @relation("Approver", fields: [approvedById], references: [id])
  approvalDate    DateTime? @map("fecha_aprobacion") @db.Timestamptz(6)
  rejectionReason String? @map("motivo_rechazo") @db.Text

  planning  Planning?
  execution Execution?
  logs      ActivityLog[]

  @@index([approvalStatus])
  @@index([executionStatus])
  @@index([createdById])
  @@index([approvedById])
  @@index([createdAt])
  @@map("actividad")
}

// ------------------------------
// Planning (includes estimated duration)
// ------------------------------

model Planning {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId               String   @unique @map("actividad_id") @db.Uuid
  plannedExecutionDate     DateTime @map("fecha_ejecucion_planeada") @db.Timestamptz(6)
  activityTime             String   @map("hora_actividad") @db.VarChar(5)
  estimatedDurationMinutes Int      @map("duracion_estimada_minutos")

  responsibleEntityId    String? @map("ente_encargado_id") @db.Uuid
  responsibleEntityOther String? @map("ente_encargado_otro") @db.VarChar(255)

  convokingInstitutionId String? @map("institucion_convoca_id") @db.Uuid

  responsibleOfficeId String  @map("oficina_responsable_id") @db.Uuid

  contactWorkerId String? @map("trabajador_contacto_id") @db.Uuid

  authorityParticipationId String? @map("participacion_autoridades_id") @db.Uuid

  observations           String? @map("observaciones") @db.Text
  additionalRequirements String? @map("requerimientos_adicionales") @db.Text

  sapiSpaceId String? @map("espacio_sapi_id") @db.Uuid

  activityTypeId  String  @map("tipo_actividad_id") @db.Uuid
  priorityId      String  @map("prioridad_id") @db.Uuid
  impactVertexId  String? @map("vertice_impacto_id") @db.Uuid

  locationId String @map("ubicacion_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  activity               Activity                       @relation(fields: [activityId], references: [id])
  responsibleEntity      Entity?                        @relation("ResponsibleEntity", fields: [responsibleEntityId], references: [id])
  convokingInstitution   Entity?                        @relation("ConvokingInstitution", fields: [convokingInstitutionId], references: [id])
  responsibleOffice      Area                           @relation("ResponsibleOffice", fields: [responsibleOfficeId], references: [id])
  contactWorker          Contact?                       @relation(fields: [contactWorkerId], references: [id])
  authorityParticipation AuthorityParticipationOption?  @relation(fields: [authorityParticipationId], references: [id])
  sapiSpace              SapiSpace?                     @relation(fields: [sapiSpaceId], references: [id])
  activityType           ActivityType                   @relation(fields: [activityTypeId], references: [id])
  priority               Priority                       @relation(fields: [priorityId], references: [id])
  impactVertex           ImpactVertex?                  @relation(fields: [impactVertexId], references: [id])
  location               Location                       @relation(fields: [locationId], references: [id])

  @@index([plannedExecutionDate])
  @@index([responsibleOfficeId])
  @@index([activityTypeId])
  @@index([sapiSpaceId])
  @@map("planificacion")
}

// ------------------------------
// Execution (includes real duration)
// ------------------------------

model Execution {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId           String   @unique @map("actividad_id") @db.Uuid
  realExecutionDate    DateTime @map("fecha_ejecucion_real") @db.Timestamptz(6)
  realDurationMinutes  Int?     @map("duracion_real_minutos")
  activityObjective    String   @map("objetivo_actividad") @db.Text
  executionDescription String   @map("descripcion_ejecucion") @db.Text
  peopleCount          Int      @map("cantidad_personas")
  totalMale            Int      @map("total_masculino")
  totalFemale          Int      @map("total_femenino")

  strategicLineId  String @map("linea_estrategica_id") @db.Uuid
  locationId       String @map("ubicacion_id") @db.Uuid
  executingOfficeId String @map("oficina_ejecutora_id") @db.Uuid
  executedById     String @map("ejecutado_por_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  activity        Activity      @relation(fields: [activityId], references: [id])
  strategicLine   StrategicLine @relation(fields: [strategicLineId], references: [id])
  location        Location      @relation(fields: [locationId], references: [id])
  executingOffice Area          @relation("ExecutingOffice", fields: [executingOfficeId], references: [id])
  executedBy      User          @relation("Executor", fields: [executedById], references: [id])

  audiencesServed ActivityAudience[]
  communesServed  ExecutionCommune[]

  @@index([realExecutionDate])
  @@index([strategicLineId])
  @@index([executingOfficeId])
  @@map("ejecucion")
}

// ------------------------------
// Bridge tables
// ------------------------------

model ActivityAudience {
  executionId    String  @map("ejecucion_id") @db.Uuid
  audienceTypeId String  @map("tipo_publico_id") @db.Uuid
  quantity       Int?    @map("cantidad")
  observation    String? @map("observacion") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  execution    Execution    @relation(fields: [executionId], references: [id])
  audienceType AudienceType @relation(fields: [audienceTypeId], references: [id])

  @@id([executionId, audienceTypeId])
  @@index([audienceTypeId])
  @@map("actividad_publico")
}

model ExecutionCommune {
  executionId String  @map("ejecucion_id") @db.Uuid
  communeId   String  @map("comuna_id") @db.Uuid
  observation String? @map("observacion") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  execution Execution @relation(fields: [executionId], references: [id])
  commune   Commune   @relation(fields: [communeId], references: [id])

  @@id([executionId, communeId])
  @@index([communeId])
  @@map("ejecucion_comuna")
}

// ------------------------------
// Audit log
// ------------------------------

model ActivityLog {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId              String   @map("actividad_id") @db.Uuid
  userId                  String   @map("usuario_id") @db.Uuid
  action                  String   @map("accion") @db.VarChar(50)
  previousApprovalStatus  String?  @map("estado_anterior_aprobacion") @db.VarChar(30)
  newApprovalStatus       String?  @map("estado_nuevo_aprobacion") @db.VarChar(30)
  previousExecutionStatus String?  @map("estado_anterior_ejecucion") @db.VarChar(30)
  newExecutionStatus      String?  @map("estado_nuevo_ejecucion") @db.VarChar(30)
  details                 Json?    @map("detalles")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  activity Activity @relation(fields: [activityId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([activityId])
  @@index([userId])
  @@index([createdAt])
  @@map("log_actividad")
}
